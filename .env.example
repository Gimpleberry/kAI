# Copy to .env and fill in. Never commit .env itself.

# Storage
KAI_DB_URL=sqlite:///./data/kai.db
KAI_DATA_DIR=./data

# API
KAI_HOST=127.0.0.1
KAI_PORT=8000

# Design parameters (can override per-session)
KAI_CBC_TASKS=20
KAI_CBC_ALTS_PER_TASK=4
KAI_MAXDIFF_TASKS=12
KAI_MAXDIFF_ITEMS_PER_TASK=4

# Estimation
KAI_DEFAULT_ESTIMATOR=mnl
KAI_BOOTSTRAP_ITERS=500

# Logging
KAI_LOG_LEVEL=INFO
